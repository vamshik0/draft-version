    "value": {
      "value": "{{(() => {\n  let currentValue = components.9fc8757d-eecd-4c23-920d-9284f50cf5a6.selectedRow.value.string_value;\n  let inputType = queries.0de5bb14-b3f6-4d36-b86c-ad03460c267b.data[\"Value Type\"].slice(5).toLowerCase();\n\n  switch (inputType) {\n    case 'string':\n      return currentValue;\n\n    case 'int':\n      return parseFloat(currentValue);\n\n    case 'float':\n      return parseFloat(currentValue);\n\n    case 'boolean':\n      return currentValue;\n\n    case 'string_array':\n      return JSON.stringify(currentValue);\n\n    case 'int_array':\n      return JSON.stringify(currentValue);\n\n    case 'float_array':\n      return currentValue.toString();\n\n    case 'boolean_array':\n      return JSON.stringify(currentValue)\n\n    case 'json':\n      return currentValue;\n  }\n})()}}"
    },
