    "text": {
      "value": "### Delete default value {{ (() => {\n  let currentValue = configValuesTable.selectedRow.value;\n  let inputType = fetchConfigDetails.data[\"Value Type\"].slice(5).toLowerCase();\n\n  switch (inputType) {\n    case 'string':\n      return currentValue;\n\n    case 'int':\n      return parseFloat(currentValue);\n      \n    case 'float':\n      return parseFloat(currentValue);\n\n    case 'boolean':\n      return currentValue;\n\n    case 'string_array':\n      return JSON.stringify(currentValue);\n\n    case 'int_array':\n      return JSON.stringify(currentValue);\n\n    case 'float_array':\n      return currentValue.toString();\n\n    case 'boolean_array':\n      return JSON.stringify(currentValue)\n\n    case 'json':\n      return currentValue;\n  }\n})() }} of {{ selectedConfig.value }} config?"
    },
