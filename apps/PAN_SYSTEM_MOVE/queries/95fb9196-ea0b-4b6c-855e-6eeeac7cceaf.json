    "query": "select\nt7.pod_delivery_date,\nsum(t7.indent) as TOTAL_INDENT,\nsum(t7.total_packets) as TOTAL_PAX,\nsum(t7.total_putaway_qty) as TOTAL_PUTAWAY,\nsum(t7.total_repack_qty) as TOTAL_REPACK\nfrom \n(\nselect t5.pod_delivery_date,\nt5.item_code,t5.product_name,t5.indent,t5.procurement_type,\nt5.total_packets,t5.total_repack_qty,t6.total_putaway_qty,\nt5.move_qty,t5.whxsku\nFROM\n(\nselect t3.pod_delivery_date,t3.item_code,t3.product_name,\nt3.indent,t3.move_qty,t3.whxsku,t3.procurement_type,\nt3.total_packets,t4.total_repack_qty\nfrom \n(\nselect\nt1.pod_delivery_date,\nt1.item_code,\nt1.product_name,\nt1.indent,\nt1.procurement_type,\nt2.total_packets,\nt1.move_qty,\nt1.whxsku\nfrom pan_fnv_indent t1\nLEFT JOIN\n(\nselect sku_id,sum(packets) as total_packets\nfrom pan_pack_report\nwhere warehouse='{{queries.58549949-0756-4cec-b5fd-ebcc3c337ef4.data[0].warehouse}}'\nand reported_at > current_date\ngroup by sku_id\n) t2\nON t1.item_code = t2.sku_id\nwhere t1.wh_selected = '{{queries.58549949-0756-4cec-b5fd-ebcc3c337ef4.data[0].warehouse}}'\nand t1.pod_delivery_date > current_date\n) t3\nleft join\n(\nselect sku_id,sum(move_qty) as total_repack_qty\nfrom pan_move_id\nwhere warehouse='{{queries.58549949-0756-4cec-b5fd-ebcc3c337ef4.data[0].warehouse}}'\nand time_stamp > current_date\ngroup by sku_id\n) t4 \nON t3.item_code = t4.sku_id\n) t5\nLEFT JOIN\n(\nselect sku_id,sum(qty) as total_putaway_qty\nfrom pan_putaway_id\nwhere warehouse='{{queries.58549949-0756-4cec-b5fd-ebcc3c337ef4.data[0].warehouse}}'\nand time_stamp > current_date\ngroup by sku_id\n) t6\nON t5.item_code = t6.sku_id\n) t7\ngroup by t7.pod_delivery_date"
  },
